# ============================================================
# AIOpsOS 部署配置文件示例
# 复制此文件为 .env 并修改相应配置
# ============================================================

# ── PostgreSQL 数据库 ──────────────────────────────────────
POSTGRES_DB=aiopsos
POSTGRES_USER=aiopsos
POSTGRES_PASSWORD=aiopsos123
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis 缓存 ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Kafka 消息队列 ─────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── AIOpsOS 后端服务 ───────────────────────────────────────
# 安全密钥 - 生产环境必须修改为随机字符串
SECRET_KEY=change-me-to-a-random-string

# JWT 配置
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 数据库连接 URL
DATABASE_URL=postgresql+asyncpg://aiopsos:aiopsos123@db:5432/aiopsos
SYNC_DATABASE_URL=postgresql://aiopsos:aiopsos123@db:5432/aiopsos

# Celery 任务队列
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# 服务类型: server | worker | allinone
# - server: 仅运行 API 服务
# - worker: 仅运行 Celery Worker
# - allinone: 同时运行 API 和内嵌 Worker (开发环境)
SERVICE_TYPE=server

# 公开访问 URL (用于生成分享链接，无尾部斜杠)
PUBLIC_URL=http://localhost:8000

# ── LLM 大语言模型配置 ─────────────────────────────────────
# 主 LLM 配置 (用于对话、分析等)
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.openai.com/v1

# Embedding 向量模型配置 (用于知识库)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# ── 知识库配置 ─────────────────────────────────────────────
# 知识库文件存储路径
WIKI_PATH=data/knowledge

# 知识库监控配置
KB_MONITOR_ENABLED=true
KB_MONITOR_POLL_INTERVAL=30
KB_MONITOR_MODEL=deepseek-v4-flash

# ── 日志配置 ───────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=data/logs
LOG_FORMAT=text
LOG_RETENTION_DAYS=30

# ── 应急协同配置 ───────────────────────────────────────────
# 进度分析间隔 (秒)
PROGRESS_ANALYSIS_INTERVAL=300
# 是否默认启用自动分析
PROGRESS_ANALYSIS_ENABLED=true

# ── 企业微信配置 (可选，用于应急协同群聊) ──────────────────
# 注意: 企业微信配置通过 NotificationChannel 在数据库中管理
# 以下为参考配置项:
# WECOM_CORP_ID=your_corp_id
# WECOM_CORP_SECRET=your_corp_secret
# WECOM_AGENT_ID=your_agent_id

# ── 邮件配置 (可选，用于应急协同通知) ──────────────────────
# 注意: 邮件配置通过 NotificationChannel 在数据库中管理
# 以下为参考配置项:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASSWORD=your_password
# SMTP_FROM=noreply@example.com
# SMTP_USE_TLS=true
